import tkinter as tk
from tkinter import ttk, messagebox
import csv
import os

# where contacts are saved
FILE_NAME = "contacts.csv"

contacts = []


def load_contacts():
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r", newline="") as file:
            reader = csv.reader(file)
            for row in reader:
                contacts.append(row)



def save_contacts():
    with open(FILE_NAME, "w", newline="") as file:
        writer = csv.writer(file)
        writer.writerows(contacts)


# show contacts in the table
def show_contacts(list_to_show):
    # clear existing rows
    table.delete(*table.get_children())

    # insert each contact into the table
    for contact in list_to_show:
        table.insert("", tk.END, values=contact)


# to add a new contact
def add_contact():
    # get input values
    first = first_entry.get()
    last = last_entry.get()
    phone = phone_entry.get()
    email = email_entry.get()

    # checking if any field is empty
    if first == "" or last == "" or phone == "" or email == "":
        messagebox.showerror("Error", "Please fill in all fields.")
        return

    contacts.append([first, last, phone, email])

    # save display
    save_contacts()
    show_contacts(contacts)

    # clearing the input fields
    first_entry.delete(0, tk.END)
    last_entry.delete(0, tk.END)
    phone_entry.delete(0, tk.END)
    email_entry.delete(0, tk.END)


# deleting the selected contact
def delete_contact():
    selected = table.selection()

    # checking if something is selected
    if not selected:
        messagebox.showerror("Error", "Please select a contact.")
        return

    # getting selected contact values
    contact_values = table.item(selected[0], "values")

    # remove from list
    contacts.remove(list(contact_values))

    
    save_contacts()
    show_contacts(contacts)


def search_contact():
    search_word = search_entry.get().lower()
    results = []

    for contact in contacts:
        # convert each field to lowercase 
        first = contact[0].lower()
        last = contact[1].lower()
        phone = contact[2].lower()
        email = contact[3].lower()

        # checking if search word appears in any field
        if (search_word in first or
            search_word in last or
            search_word in phone or
            search_word in email):
            results.append(contact)

   
    show_contacts(results)


def show_all():
    search_entry.delete(0, tk.END)
    show_contacts(contacts)


# setting up GUI

root = tk.Tk()
root.title("Phonebook Management System")
root.geometry("750x500")


load_contacts()

tk.Label(root, text="Search:").pack()
search_entry = tk.Entry(root, width=40)
search_entry.pack()

tk.Button(root, text="Search", command=search_contact).pack()
tk.Button(root, text="Show All", command=show_all).pack()

columns = ("First Name", "Last Name", "Phone Number", "Email")
table = ttk.Treeview(root, columns=columns, show="headings")

for column in columns:
    table.heading(column, text=column)

table.pack(pady=10)

# making the entry form
tk.Label(root, text="First Name").pack()
first_entry = tk.Entry(root)
first_entry.pack()

tk.Label(root, text="Last Name").pack()
last_entry = tk.Entry(root)
last_entry.pack()

tk.Label(root, text="Phone Number").pack()
phone_entry = tk.Entry(root)
phone_entry.pack()

tk.Label(root, text="Email").pack()
email_entry = tk.Entry(root)
email_entry.pack()

# adding buttons
tk.Button(root, text="Add Contact", command=add_contact).pack(pady=5)
tk.Button(root, text="Delete Selected Contact", command=delete_contact).pack()

show_contacts(contacts)

root.mainloop()
